# Copy this file to .env and fill in your values.
# Do not commit .env or service-account.json to version control.

# Ollama OpenAI-compatible base URL for receipt image OCR (parse_receipt.js).
# Default in code is Ollama Cloud; set OLLAMA_API_KEY below.
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_API_KEY=your_key_from_https://ollama.com/settings/keys
#
# Local Ollama only (no ollama.com API key): override base URL.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Vision model for parse_receipt.js. Default in code: qwen3-vl:8b (Ollama Cloud / OpenAI vision example).
# Override for local runs, e.g. after ollama pull:
# OLLAMA_VISION_MODEL=llava:7b
# OLLAMA_VISION_MODEL=glm-4.7-flash:latest

# Local CSV: relative to this skill folder, or absolute path still inside this folder (no .. escape)
# EXPENSES_CSV_PATH=expenses.csv

# Optional: allow receipt images under this directory (e.g. OpenClaw workspace attachments). Defaults to skill folder only.
# OPENCLAW_WORKSPACE=/Users/you/.openclaw/workspace

# Cloud storage (only needed if user says storage=cloud): Google Sheet ID from URL .../d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here
